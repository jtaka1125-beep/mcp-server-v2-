# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
logs/*.log
logs/*.log.*
logs/*.json

# Data: 既存DBは共有なのでここには置かない
data/

# Runtime state (heartbeat, pid) — never commit
server.heartbeat
server.pid

